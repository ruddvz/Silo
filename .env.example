# Set to "true" to seed the vault with demo documents (development / demos only).
# VITE_ENABLE_DEMO_DATA=true

# Copy to .env.local for local dev. Omit both Supabase vars to use local-only Silo Lists on this device.
# Vault files always stay on-device; Lists sync is optional and separate from the document vault.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
