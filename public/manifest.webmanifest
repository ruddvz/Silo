{
  "name": "Silo — Private Vault",
  "short_name": "Silo",
  "description": "Your local-first, private document vault.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "window-controls-overlay"],
  "orientation": "any",
  "background_color": "#0f0f10",
  "theme_color": "#0f0f10",
  "categories": ["productivity", "utilities"],
  "dir": "ltr",
  "lang": "en",
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["application/pdf", "image/*", "audio/*", "text/*", "video/*", "*/*"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".jpg", ".jpeg", ".png", ".webp", ".gif"],
        "audio/*": [".mp3", ".m4a", ".wav", ".ogg"],
        "text/plain": [".txt", ".md"]
      }
    }
  ],
  "handle_links": "preferred"
}
